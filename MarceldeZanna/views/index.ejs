<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Benutzerformular</title>
  <style>
    :root {
      color-scheme: dark;
      font-family: Inter, system-ui, sans-serif;
      background: #121212;
      color: #f5f5f5;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 2rem;
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    }

    .card {
      width: min(100%, 480px);
      padding: 2rem;
      border-radius: 24px;
      background: rgba(15, 23, 42, 0.92);
      border: 1px solid rgba(148, 163, 184, 0.18);
      box-shadow: 0 24px 80px rgba(15, 23, 42, 0.45);
    }

    .card h1 {
      margin: 0 0 1.25rem;
      font-size: clamp(1.6rem, 2vw, 2rem);
      letter-spacing: -0.03em;
    }

    .field {
      display: grid;
      gap: 0.5rem;
      margin-bottom: 1rem;
    }

    label {
      font-size: 0.95rem;
      color: #cbd5e1;
    }

    input[type="text"],
    input[type="number"] {
      width: 100%;
      padding: 0.95rem 1rem;
      border-radius: 14px;
      border: 1px solid rgba(148, 163, 184, 0.2);
      background: #0f172a;
      color: #f8fafc;
      font-size: 1rem;
    }

    input[type="text"]::placeholder,
    input[type="number"]::placeholder {
      color: #94a3b8;
    }

    .radio-group {
      display: grid;
      gap: 0.75rem;
      padding: 1rem;
      border-radius: 18px;
      border: 1px solid rgba(148, 163, 184, 0.18);
      background: rgba(255, 255, 255, 0.03);
    }

    .radio-option {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.85rem 1rem;
      border-radius: 14px;
      transition: background 0.2s ease;
      cursor: pointer;
    }

    .radio-option:hover {
      background: rgba(148, 163, 184, 0.1);
    }

    .radio-option input {
      accent-color: #38bdf8;
      width: 1.1rem;
      height: 1.1rem;
    }

    .radio-option span {
      color: #e2e8f0;
      font-size: 0.98rem;
    }

    button {
      width: 100%;
      padding: 0.95rem 1rem;
      border: none;
      border-radius: 14px;
      background: linear-gradient(135deg, #38bdf8, #818cf8);
      color: #0f172a;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.2s ease, opacity 0.2s ease;
    }

    button:hover {
      transform: translateY(-1px);
      opacity: 0.97;
    }
  </style>
</head>
<body>
  <main class="card">
    <h1>Benutzerinformation</h1>
    <form method="POST" action="/willkommen">
      <div class="field">
        <label for="username">Username</label>
        <input id="username" name="username" type="text" placeholder="Dein Name" required />
      </div>

      <div class="field">
        <label for="age">Alter</label>
        <input id="age" name="age" type="number" min="1" placeholder="Dein Alter" required />
      </div>

      <div class="field">
        <label>Händigkeit</label>
        <div class="radio-group">
          <label class="radio-option">
            <input type="radio" name="handedness" value="rechtshaender" required />
            <span>Rechtshänder</span>
          </label>
          <label class="radio-option">
            <input type="radio" name="handedness" value="linkshaender" />
            <span>Linkshänder</span>
          </label>
          <label class="radio-option">
            <input type="radio" name="handedness" value="beides" />
            <span>Beides</span>
          </label>
        </div>
      </div>

      <button type="submit">Absenden</button>
    </form>
  </main>
</body>
</html>