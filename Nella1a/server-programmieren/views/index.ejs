<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Backend Web-App</title>
  </head>
  <body>
    <main>
      <form method="post" action="/welcome">
        <label for="username"
          >Name:
          <input type="text" name="username" id="username" required />
        </label>
        <fieldset>
          <legend>Do you agree to the terms?</legend>
          <label
            ><input type="radio" name="radio" value="yes" required /> Yes</label
          >
          <label><input type="radio" name="radio" value="no" /> No</label>
        </fieldset>
        <fieldset>
          <legend>Favorite Fruits?</legend>
          <label
            ><input type="checkbox" name="fruits" value="orange" />orange</label
          >
          <label
            ><input type="checkbox" name="fruits" value="kiwi" />kiwi</label
          >
          <label
            ><input
              type="checkbox"
              name="fruits"
              value="cherries"
            />cherries</label
          >
        </fieldset>
        <button>submit</button>
      </form>
    </main>
  </body>
</html>
